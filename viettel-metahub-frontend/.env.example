# Copy this file to .env.local for local development

# Proxy target: DataHub frontend (Play Framework), which handles auth and
# proxies /api/* and /openapi/* to GMS — same as datahub-web-react dev setup.
# Default: http://localhost:9002 (datahub-frontend container / Play server)
#
# To connect directly to GMS (without Play), change to http://localhost:8080
# and note that /logIn auth will not work — use a Personal Access Token instead.
VITE_PROXY_TARGET=http://localhost:9002
